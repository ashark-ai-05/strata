{
  "name": "opencanvas",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "cli": "tsx src/cli.ts",
    "mcp": "tsx src/mcp-server/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "backend": "bash scripts/backend.sh",
    "backend:check": "bash scripts/backend.sh --smoke",
    "dev": "concurrently --names 'backend,app' --kill-others --kill-others-on-fail 'pnpm backend' 'pnpm app'",
    "app": "vite --config app/vite.config.ts",
    "app:build": "vite build --config app/vite.config.ts",
    "app:preview": "vite preview --config app/vite.config.ts",
    "electron": "electron .",
    "electron:dev": "concurrently --names 'dev,electron' --kill-others --kill-others-on-fail 'pnpm dev' 'electron --no-sandbox .'",
    "electron:rebuild": "electron-builder install-app-deps",
    "dist": "pnpm app:build && electron-builder",
    "dist:mac": "pnpm app:build && electron-builder --mac",
    "dist:win": "pnpm app:build && electron-builder --win",
    "dist:linux": "pnpm app:build && electron-builder --linux"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.0",
    "@anthropic-ai/claude-agent-sdk": "*",
    "@anthropic-ai/sdk": "*",
    "@hono/node-server": "^1.10.0",
    "@huggingface/transformers": "^4.0.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@sourcegraph/amp-sdk": "*",
    "ai": "^6.0.0",
    "better-sqlite3": "^11.0.0",
    "cron-parser": "^5.5.0",
    "framer-motion": "^12.38.0",
    "hono": "^4.12.18",
    "lucide-react": "^0.460.0",
    "mammoth": "^1.12.0",
    "ollama": "*",
    "onnxruntime-node": "^1.20.0",
    "openai": "*",
    "pdf-parse": "^2.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.0.0",
    "remark-gfm": "^4.0.0",
    "shiki": "^4.0.0",
    "sonner": "^2.0.7",
    "sqlite-vec": "^0.1.6",
    "tldraw": "^3.0.0",
    "tree-sitter-typescript": "^0.23.0",
    "web-tree-sitter": "^0.24.0",
    "xlsx": "npm:@e965/xlsx@^0.20.3",
    "yaml": "^2.8.3",
    "zod": "*",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@modelcontextprotocol/server-filesystem": "*",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "*",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "electron": "^39.8.5",
    "electron-builder": "^26.0.0",
    "ffmpeg-static": "^5.3.0",
    "jsdom": "^25.0.0",
    "playwright": "^1.59.1",
    "tailwindcss": "^4.0.0",
    "tsx": "*",
    "typescript": "*",
    "vite": "^6.0.0",
    "vitest": "*"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "onnxruntime-node",
      "protobufjs",
      "sharp",
      "electron"
    ],
    "overrides": {
      "tar": "^7.5.11",
      "@tootallnate/once": "^3.0.1",
      "@anthropic-ai/sdk": "^0.92.0"
    }
  },
  "build": {
    "appId": "com.opencanvas.app",
    "productName": "OpenCanvas",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "app/dist/**/*",
      "dist-backend/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/{better-sqlite3,onnxruntime-node,sqlite-vec,web-tree-sitter,tree-sitter-typescript}/**"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Development"
    }
  }
}

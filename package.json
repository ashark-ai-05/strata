{
  "name": "llm-wiki",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "cli": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "backend": "bash scripts/backend.sh",
    "backend:check": "bash scripts/backend.sh --smoke",
    "dev:full": "concurrently --names 'backend,space-agent' --kill-others --kill-others-on-fail 'pnpm backend' 'pnpm dev'",
    "setup": "bash scripts/setup-space-agent.sh",
    "dev": "bash scripts/dev-space-agent.sh",
    "dev:check": "bash scripts/dev-space-agent.sh --smoke"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "*",
    "@anthropic-ai/sdk": "*",
    "@hono/node-server": "^1.10.0",
    "@huggingface/transformers": "^4.0.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^11.0.0",
    "hono": "^4.0.0",
    "ollama": "*",
    "onnxruntime-node": "^1.20.0",
    "openai": "*",
    "sqlite-vec": "^0.1.6",
    "tree-sitter-typescript": "^0.23.0",
    "web-tree-sitter": "^0.24.0",
    "yaml": "^2.8.3",
    "zod": "*"
  },
  "devDependencies": {
    "@modelcontextprotocol/server-filesystem": "*",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "*",
    "concurrently": "^9.0.0",
    "tsx": "*",
    "typescript": "*",
    "vitest": "*"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "onnxruntime-node",
      "protobufjs",
      "sharp"
    ]
  }
}
